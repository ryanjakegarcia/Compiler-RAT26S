/* this is comment for this sample code which
converts Fahrenheit into Celcius */
@
function convertx (fahr integer)
{
return 5 * (fahr -32) / 9;
}
@
integer low, high, step; /* declarations */
@
read (low, high, step);
while (low <= high )
{ write (low);
write (convertx (low));
low = low + step;
}
@
